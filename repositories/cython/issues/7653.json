    "author_association": "MEMBER",
    "body": "\nReproducer. Change following line:\n\nhttps://github.com/cython/cython/blob/1553d22387d5a5f5211f98b81a0d16eee03e2496/Cython/Compiler/FlowControl.pxd#L10\n\nto\n\n```cython\ncdef public dict[object, NameAssignment] gen\n```\n\nthe compilation fails with:\n\n```python\nTraceback (most recent call last):\n  File \"/home/dev/cython/.venv/bin/cython\", line 10, in <module>\n    sys.exit(setuptools_main())\n             ~~~~~~~~~~~~~~~^^\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 821, in setuptools_main\n    return main(command_line = 1)\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 849, in main\n    result = compile(sources, options)\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 740, in compile\n    return compile_multiple(source, options, cache)\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 699, in compile_multiple\n    result = compile_single(source, options, full_module_name=options.module_name, cache=cache, context=context)\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 670, in compile_single\n    return run_pipeline(source, options, full_module_name, context)\n  File \"/home/dev/cython/Cython/Compiler/Main.py\", line 566, in run_pipeline\n    err, enddata = Pipeline.run_pipeline(pipeline, source)\n                   ~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Pipeline.py\", line 418, in run_pipeline\n    data = run(phase, data)\n  File \"/home/dev/cython/Cython/Compiler/Pipeline.py\", line 400, in run\n    return phase(data)\n  File \"/home/dev/cython/Cython/Compiler/Pipeline.py\", line 50, in generate_pyx_code_stage\n    module_node.process_implementation(options, result)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/ModuleNode.py\", line 314, in process_implementation\n    self.generate_c_code(env, options, result)\n    ~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/ModuleNode.py\", line 614, in generate_c_code\n    self.body.generate_function_definitions(env, code)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Nodes.py\", line 437, in generate_function_definitions\n    stat.generate_function_definitions(env, code)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Nodes.py\", line 437, in generate_function_definitions\n    stat.generate_function_definitions(env, code)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Nodes.py\", line 5696, in generate_function_definitions\n    self.body.generate_function_definitions(self.scope, code)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Nodes.py\", line 437, in generate_function_definitions\n    stat.generate_function_definitions(env, code)\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^\n  File \"/home/dev/cython/Cython/Compiler/Nodes.py\", line 2567, in generate_function_definitions\n    code.exit_cfunc_scope()\n    ~~~~~~~~~~~~~~~~~~~~~^^\n  File \"/home/dev/cython/Cython/Compiler/Code.py\", line 2807, in exit_cfunc_scope\n    self.funcstate.validate_exit()\n    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~^^\n  File \"/home/dev/cython/Cython/Compiler/Code.py\", line 1201, in validate_exit\n    raise RuntimeError(msg)\nRuntimeError: TEMPGUARD: Temps left over at end of 'mark_argument': __pyx_t_3 [Python object]\n```\nInteresting is that I was **not able to create reproducer**. Also when following line is used instead:\n```cython\ncdef public dict[typing.Any, NameAssignment] gen\n```\ncompilation is successful.",
